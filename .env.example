STRIPE_SECRET_KEY=sk_live_xxxx

# Webhook secret — gerado ao criar o endpoint no Stripe
# URL do endpoint: https://linkey.cloud/api/stripe/webhook
# Eventos: checkout.session.completed, customer.subscription.created,
#          customer.subscription.updated, customer.subscription.deleted,
#          invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# IDs dos preços criados no Stripe (Products → Add product)
# Pro — R$19/mês · R$182,40/ano
STRIPE_PRICE_PRO_MONTHLY=price_xxxx
STRIPE_PRICE_PRO_YEARLY=price_xxxx

# All-Star — R$99,99/mês · R$1.019,90/ano
STRIPE_PRICE_ALLSTAR_MONTHLY=price_xxxx
STRIPE_PRICE_ALLSTAR_YEARLY=price_xxxx

# ─── RESEND ─────────────────────────────────
# Encontre em: resend.com → API Keys
